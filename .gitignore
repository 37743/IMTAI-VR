*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Mono auto generated files
mono_crash.*

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# TestRunner generated files
InitTestScene*.unity*

# Addressables default ignores, before user customizations
/VR Industrial Training/ServerData
/VR Industrial Training/[Aa]ssets/StreamingAssets/aa*
/VR Industrial Training/[Aa]ssets/AddressableAssetsData/link.xml*
/VR Industrial Training/[Aa]ssets/Addressables_Temp*
# By default, Addressables content builds will generate addressables_content_state.bin
# files in platform-specific subfolders, for example:
# /Assets/AddressableAssetsData/OSX/addressables_content_state.bin
/VR Industrial Training/[Aa]ssets/AddressableAssetsData/*/*.bin*

# Visual Scripting auto-generated files
/VR Industrial Training/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db
/VR Industrial Training/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Flow/UnitOptions.db.meta
/VR Industrial Training/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers
/VR Industrial Training/[Aa]ssets/Unity.VisualScripting.Generated/VisualScripting.Core/Property Providers.meta

# Auto-generated scenes by play mode tests
/VR Industrial Training/[Aa]ssets/[Ii]nit[Tt]est[Ss]cene*.unity*